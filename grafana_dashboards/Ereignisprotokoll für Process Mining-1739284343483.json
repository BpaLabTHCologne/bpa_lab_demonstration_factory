        {
          "datasource": {
            "type": "trino-datasource",
            "uid": "de5zt5g5uujgga"
          },
          "format": 1,
          "rawSQL": "WITH variable AS (\n    SELECT DISTINCT\n        processInstanceKey,\n        TRIM(BOTH '\"' FROM CAST(value AS VARCHAR)) AS orderNumber\n    FROM elasticsearch.default.\"operate-variable-8.3.0_alias\" AS v\n    WHERE v.\"name\" = 'orderNumber'\n),\norder_products AS (\n    SELECT\n        coi.order_id,\n        array_join(array_agg(CAST(coi.quantity AS VARCHAR) || 'x ' || coi.bike_model_id), ', ') AS products\n    FROM mysql.bpa_lab_demonstration_factory.customer_order_item AS coi\n    GROUP BY coi.order_id\n)\nSELECT\n    variable.orderNumber AS case_id,\n    flownode.flowNodeId AS activity,\n    flownode.startDate AS start_timestamp,\n    flownode.endDate AS end_timestamp,\n    flownode.position AS sorting_column,\n    flownode.state AS activity_state,\n    flownode.incident AS incident_occured,\n    orders.customer_name,\n    order_products.products\nFROM elasticsearch.default.\"operate-flownode-instance-8.3.1_alias\" AS flownode\nLEFT JOIN variable\n    ON flownode.processInstanceKey = variable.processInstanceKey\nLEFT JOIN mysql.bpa_lab_demonstration_factory.customer_order AS orders\n    ON variable.orderNumber = orders.customer_order_number\nLEFT JOIN order_products\n    ON orders.customer_order_number = order_products.order_id\nWHERE flownode.type NOT IN ('EXCLUSIVE_GATEWAY', 'RECEIVE_TASK')\n    AND variable.orderNumber IS NOT NULL\n    AND flownode.flowNodeId IS NOT NULL\n    AND flownode.startDate IS NOT NULL\n    AND flownode.endDate IS NOT NULL\n    AND flownode.startDate BETWEEN $__timeFrom() AND $__timeTo()\nORDER BY sorting_column",
          "refId": "A"
        }
      ],
      "title": "Ereignisprotokoll",
      "type": "table"
    }
