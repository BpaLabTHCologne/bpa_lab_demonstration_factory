      "id": "Field_18j0ent"
    },
    {
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>ErrorMsg</title>\n    <style>\n        .ErrorMsg {\n            background-color: #fff;\n            border: 1px solid #e0e0e0;\n            border-radius: 0px;\n            padding: 20px;\n          \n        }\n\n        .ErrorMsg.good{\n            border-left: 10px solid green;\n        }\n        .ErrorMsg.medium{\n            border-left: 10px solid orange;\n        }\n        .ErrorMsg.bad{\n            border-left: 10px solid red;\n        }\n\n        \n        .ErrorMsg-header {\n            font-size: 18px;\n            font-weight: bold;\n            color: #2f2f2f;\n            margin-bottom: 10px;\n        }\n\n        .ErrorMsg-message {\n            font-size: 16px;\n            color: #2f2f2f;\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"ErrorMsg {{warningColor}}\">\n        <div class=\"ErrorMsg-header\">{{if (warningColor = \"good\") then  \"Low Requirement\" else if (warningColor = \"medium\") then \"Medium Requirement!\" else \"High Requirement!\"}}</div>\n        <div class=\"ErrorMsg-message\">\n        {{errorMessage}}\n        </div>\n    </div>\n\n    \n\n</body>\n</html>\n",
      "type": "html",
      "layout": {
        "row": "Row_1eeuyhx",
        "columns": null
      },
      "id": "Field_0rcx6e6"
    },
    {
      "computeOn": "change",
      "type": "expression",
      "layout": {
        "row": "Row_0zhkxll",
        "columns": 8
      },
      "id": "Field_1f87dfi",
      "key": "warningColor",
      "expression": "=if count(produceBikeModelList) < 1 then \"good\" else if count(reserveBikeInstanceList) < 1 then \"bad\"  else \"medium\""
    },
    {
      "computeOn": "change",
      "type": "expression",
      "layout": {
        "row": "Row_0zhkxll",
        "columns": null
      },
      "id": "Field_1ju8umi",
      "key": "errorMessage",
      "expression": "=if count(produceBikeModelList) < 1 then \"All ordered Bikes are in Stock an can be reserved for Customer\" else if count(reserveBikeInstanceList) < 1 then \"All ordered Bikes need to be produced for Customer\"  else \"Some Bikes are in Stock and some need to be produced for Customer\""
    }
  ],
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.7.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.41.0"
  },
  "schemaVersion": 19,
  "id": "showOrderForm",
  "type": "default"
}