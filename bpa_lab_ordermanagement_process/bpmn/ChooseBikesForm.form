{
  "components": [
    {
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Form Header</title>\n    <style>\n      .form-header{\n        display:flex;\n        align-items:center;\n        justify-content:space-between;\n        gap:16px;\n        padding:16px 18px;\n        margin: 0px;\n        background:#f4f4f4;\n        border:1px solid #8d8d8d;\n        border-radius:8px;\n      }\n      .form-header-taskname{\n        margin:0;\n        font-size:26px;\n        font-weight:800;\n        letter-spacing:.2px;\n        line-height:1.1;\n      }\n      .form-header-right{\n        display:flex;\n        align-items:center;\n        gap:30px;\n        flex-shrink:0;\n      }\n      .form-header-role{\n        font-size:13px;\n        font-weight:500;\n        padding:6px 10px;\n        border-radius:9px;\n        background:#0000000f;\n        white-space:nowrap;\n      }\n      .form-header-logo{\n        height:40px;\n        width:auto;\n        display:block;\n      }\n    </style>\n  </head>\n  <body>\n    <div class=\"form-header\"aria-label=\"Choose Bikes Header\">\n        <div class=\"form-header-left\">\n        <h1 class=\"form-header-taskname\">Choose Bikes</h1>\n    \n        </div>\n    \n        <div class=\"form-header-right\">\n          <span class=\"form-header-role\" aria-label=\"Job role\">\n          <strong>Job role:</strong> Customer Service\n          </span>\n          <img\n          class=\"form-header-logo\"\n          src=\"https://www.th-koeln.de/img/logo.svg\"\n          alt=\"TH Köln logo\"\n          loading=\"lazy\"\n          />\n        </div>\n    </div>\n  </body>\n</html>",
      "type": "html",
      "layout": {
        "row": "Row_1qgzllu",
        "columns": null
      },
      "id": "Field_0oojwfz"
    },
    {
      "label": "Customer Information",
      "components": [
        {
          "label": "First Name",
          "type": "textfield",
          "layout": {
            "row": "Row_1g81o5z",
            "columns": 8
          },
          "id": "Field_15b4duk",
          "key": "firstName",
          "validate": {
            "pattern": "",
            "required": true,
            "minLength": "2"
          },
          "description": "e.g.: John"
        },
        {
          "label": "Last Name",
          "type": "textfield",
          "layout": {
            "row": "Row_1g81o5z",
            "columns": 8
          },
          "id": "Field_1dx2i62",
          "key": "lastName",
          "validate": {
            "required": true,
            "minLength": "2"
          },
          "description": "e.g.: Doe"
        },
        {
          "label": "Email",
          "type": "textfield",
          "layout": {
            "row": "Row_1ixu1lr",
            "columns": 8
          },
          "id": "Field_04tmiuh",
          "key": "email",
          "validate": {
            "required": true,
            "validationType": "email"
          },
          "description": "e.g.: example@domain.com"
        },
        {
          "computeOn": "change",
          "type": "expression",
          "layout": {
            "row": "Row_1ixu1lr",
            "columns": null
          },
          "id": "Field_0bkpus1",
          "key": "name",
          "expression": "=orderCustomer.firstName + \" \" + orderCustomer.lastName\n"
        },
        {
          "computeOn": "change",
          "type": "expression",
          "layout": {
            "row": "Row_1ixu1lr",
            "columns": null
          },
          "id": "Field_017l98r",
          "key": "adress",
          "expression": "=orderCustomer.street + \" \" + orderCustomer.number + \", \" + orderCustomer.zip + \" \" + orderCustomer.city\n\n"
        },
        {
          "label": "Streetname",
          "type": "textfield",
          "layout": {
            "row": "Row_1049son",
            "columns": 12
          },
          "id": "Field_1xe8qkw",
          "key": "street",
          "validate": {
            "required": true,
            "minLength": "3"
          },
          "description": "e.g.: Samplestreet"
        },
        {
          "label": "Housenumber",
          "type": "textfield",
          "layout": {
            "row": "Row_1049son",
            "columns": null
          },
          "id": "Field_0vofgs7",
          "key": "number",
          "validate": {
            "required": true,
            "minLength": "1",
            "maxLength": "6"
          },
          "description": "e.g.: 13a"
        },
        {
          "label": "ZIP-Code",
          "type": "textfield",
          "layout": {
            "row": "Row_1jfpt2v",
            "columns": null
          },
          "id": "Field_02mw9ya",
          "key": "zip",
          "validate": {
            "required": true,
            "minLength": "3"
          },
          "description": "e.g.: 54321"
        },
        {
          "label": "City",
          "type": "textfield",
          "layout": {
            "row": "Row_1jfpt2v",
            "columns": 8
          },
          "id": "Field_10sus28",
          "key": "city",
          "validate": {
            "required": true,
            "minLength": "3"
          },
          "description": "e.g.: Anytown"
        }
      ],
      "showOutline": false,
      "type": "group",
      "layout": {
        "row": "Row_1tkxr3d",
        "columns": null
      },
      "id": "Field_1ew2xu8",
      "path": "orderCustomer"
    },
    {
      "label": "Order Details",
      "components": [
        {
          "label": "Bike Models",
          "components": [
            {
              "label": "Title",
              "type": "textfield",
              "layout": {
                "row": "Row_1ir90z1",
                "columns": 6
              },
              "id": "Field_17sgzym",
              "key": "title",
              "readonly": true
            },
            {
              "label": "Weight",
              "type": "textfield",
              "layout": {
                "row": "Row_1ir90z1",
                "columns": 4
              },
              "id": "Field_1ttjyce",
              "key": "weight",
              "readonly": true
            },
            {
              "label": "Color",
              "type": "textfield",
              "layout": {
                "row": "Row_1ir90z1",
                "columns": 3
              },
              "id": "Field_01h2v3l",
              "key": "color",
              "readonly": true
            },
            {
              "label": "Amount",
              "type": "number",
              "layout": {
                "row": "Row_1ir90z1",
                "columns": 3
              },
              "id": "Field_0yjqaxj",
              "key": "amount",
              "readonly": "=if confirmationChecked = true then true else false",
              "defaultValue": 0,
              "validate": {
                "min": "0",
                "required": false,
                "max": "99"
              },
              "increment": "1",
              "disabled": false,
              "appearance": {}
            }
          ],
          "showOutline": false,
          "isRepeating": true,
          "allowAddRemove": false,
          "defaultRepetitions": 1,
          "type": "dynamiclist",
          "layout": {
            "row": "Row_1jlt6wn",
            "columns": null
          },
          "id": "Field_1yrz78n",
          "path": "offerBikeModelList"
        },
        {
          "subtype": "date",
          "dateLabel": "Order Date",
          "type": "datetime",
          "layout": {
            "row": "Row_0d5wx16",
            "columns": 4
          },
          "id": "Field_01j0tcb",
          "key": "orderDate",
          "disallowPassedDates": true,
          "validate": {
            "required": true
          }
        }
      ],
      "showOutline": true,
      "type": "group",
      "layout": {
        "row": "Row_16nrzfg",
        "columns": null
      },
      "id": "Field_171ftw4"
    },
    {
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>ErrorMsg</title>\n    <style>\n        .ErrorMsg {\n            background-color: #fff;\n            border: 1px solid #e0e0e0;\n            border-radius: 0px;\n            padding: 20px;\n          \n        }\n\n        .ErrorMsg.good{\n            border-left: 10px solid green;\n        }\n        .ErrorMsg.medium{\n            border-left: 10px solid orange;\n        }\n        .ErrorMsg.bad{\n            border-left: 10px solid red;\n        }\n\n        \n        .ErrorMsg-header {\n            font-size: 18px;\n            font-weight: bold;\n            color: #2f2f2f;\n            margin-bottom: 10px;\n        }\n\n        .ErrorMsg-message {\n            font-size: 16px;\n            color: #2f2f2f;\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"ErrorMsg {{warningColor}}\">\n        <div class=\"ErrorMsg-header\">{{if (warningColor = \"good\") then \"Checked!\" else \"Warning!\"}}</div>\n        <div class=\"ErrorMsg-message\">\n        {{errorMessage}}\n        </div>\n    </div>\n\n    \n\n</body>\n</html>\n",
      "type": "html",
      "layout": {
        "row": "Row_1yd28eu",
        "columns": null
      },
      "id": "Field_04492eh"
    },
    {
      "label": "I checked my Order and accept the Terms of Use",
      "type": "checkbox",
      "layout": {
        "row": "Row_1f89oja",
        "columns": 9
      },
      "id": "Field_0595cep",
      "key": "confirmationChecked",
      "readonly": "=if count(offerBikeModelList[amount != 0 and amount != null]) = 0 then true else false",
      "validate": {
        "required": true
      }
    },
    {
      "computeOn": "change",
      "type": "expression",
      "layout": {
        "row": "Row_1f89oja",
        "columns": 3
      },
      "id": "Field_05irinb",
      "key": "warningColor",
      "expression": "=if count(offerBikeModelList[amount != 0 and amount != null]) = 0 then \"bad\" else if confirmationChecked = false then \"medium\" else  \"good\""
    },
    {
      "computeOn": "change",
      "type": "expression",
      "layout": {
        "row": "Row_1f89oja",
        "columns": 3
      },
      "id": "Field_1h1uxxq",
      "key": "errorMessage",
      "expression": "=if count(offerBikeModelList[amount != 0 and amount != null]) = 0 then \"Please choose at least one bike.\" else if confirmationChecked = false then \"Please check your order and accept the Terms of use \" else  \"If no field is empty or marked you're good to go\""
    }
  ],
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.7.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.41.0"
  },
  "schemaVersion": 19,
  "id": "chooseBikesForm",
  "type": "default"
}