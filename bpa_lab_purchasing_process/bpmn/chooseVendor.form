{
  "components": [
    {
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Form Header</title>\n    <style>\n      .form-header{\n        display:flex;\n        align-items:center;\n        justify-content:space-between;\n        gap:16px;\n        padding:16px 18px;\n        margin: 0px;\n        background:#f4f4f4;\n        border:1px solid #8d8d8d;\n        border-radius:8px;\n      }\n      .form-header-taskname{\n        margin:0;\n        font-size:26px;\n        font-weight:800;\n        letter-spacing:.2px;\n        line-height:1.1;\n      }\n      .form-header-right{\n        display:flex;\n        align-items:center;\n        gap:30px;\n        flex-shrink:0;\n      }\n      .form-header-role{\n        font-size:13px;\n        font-weight:500;\n        padding:6px 10px;\n        border-radius:9px;\n        background:#0000000f;\n        white-space:nowrap;\n      }\n      .form-header-logo{\n        height:40px;\n        width:auto;\n        display:block;\n      }\n    </style>\n  </head>\n  <body>\n    <div class=\"form-header\"aria-label=\"Choose Vendor\">\n        <div class=\"form-header-left\">\n        <h1 class=\"form-header-taskname\">Choose Vendor</h1>\n    \n        </div>\n    \n        <div class=\"form-header-right\">\n          <span class=\"form-header-role\" aria-label=\"Job role\">\n          <strong>Job role:</strong> Purchasing Clerk\n          </span>\n          <img\n          class=\"form-header-logo\"\n          src=\"https://www.th-koeln.de/img/logo.svg\"\n          alt=\"TH Köln logo\"\n          loading=\"lazy\"\n          />\n        </div>\n    </div>\n  </body>\n</html>",
      "type": "html",
      "layout": {
        "row": "Row_0kyreb8",
        "columns": null
      },
      "id": "Field_0ut8cia"
    },
    {
      "label": "Purchase Order",
      "components": [
        {
          "label": "Title",
          "type": "textfield",
          "layout": {
            "row": "Row_1pzqm9t",
            "columns": 6
          },
          "id": "Field_016mxd6",
          "key": "purchaseBikeComponent.title",
          "readonly": "on"
        },
        {
          "label": "Amount (adjustable)",
          "type": "number",
          "layout": {
            "row": "Row_1pzqm9t",
            "columns": 3
          },
          "id": "Field_11lnh3q",
          "key": "purchaseBikeComponent.amount",
          "readonly": false,
          "validate": {
            "min": "=purchaseCount",
            "required": true,
            "max": "=purchaseCount * 2"
          }
        },
        {
          "height": 60,
          "type": "spacer",
          "layout": {
            "row": "Row_1pzqm9t",
            "columns": 3
          },
          "id": "Field_1r48poj"
        },
        {
          "label": "Purchase Order Number",
          "type": "textfield",
          "layout": {
            "row": "Row_1pzqm9t",
            "columns": 4
          },
          "id": "Field_0i66gq1",
          "key": "purchaseOrderNumber",
          "readonly": true
        }
      ],
      "showOutline": true,
      "type": "group",
      "layout": {
        "row": "Row_1gscbz1",
        "columns": 15
      },
      "id": "Field_1s0ya40",
      "path": "purchaseComponentDTO"
    },
    {
      "label": "Vendor list for bikecomponent",
      "type": "select",
      "layout": {
