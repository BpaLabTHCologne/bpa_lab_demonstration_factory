    {
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>ErrorMsg</title>\n    <style>\n        .ErrorMsg {\n            background-color: #fff;\n            border: 2px solid black;\n            height: 180px;\n            border-radius: 0px;\n            padding: 20px;\n            \n        }\n\n        .ErrorMsg.WHITE{\n            background-color: white;\n        }\n        .ErrorMsg.BLUE{\n            background-color: blue;\n            border: 0px;\n        }\n        .ErrorMsg.RED{\n            background-color: red;\n            border: 0px;\n         }\n\n        \n        .ErrorMsg-header {\n            font-size: 18px;\n            font-weight: bold;\n            color: #2f2f2f;\n            margin-bottom: 10px;\n        }\n\n        .ErrorMsg-message {\n            font-size: 16px;\n            color: #2f2f2f;\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"ErrorMsg {{orderType}} \">\n  \n    </div>\n\n    \n\n</body>\n</html>\n",
