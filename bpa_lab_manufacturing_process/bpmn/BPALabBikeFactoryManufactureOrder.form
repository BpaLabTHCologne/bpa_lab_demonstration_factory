    {
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>ErrorMsg</title>\n    <style>\n        .ErrorMsg {\n            background-color: #fff;\n            border: 1px solid #e0e0e0;\n            border-radius: 0px;\n            padding: 20px;\n            \n        }\n\n        .ErrorMsg.good{\n            border-left: 10px solid green;\n        }\n        .ErrorMsg.medium{\n            border-left: 10px solid orange;\n        }\n        .ErrorMsg.bad{\n            border-left: 10px solid red;\n        }\n\n        \n        .ErrorMsg-header {\n            font-size: 18px;\n            font-weight: bold;\n            color: #2f2f2f;\n            margin-bottom: 10px;\n        }\n\n        .ErrorMsg-message {\n            font-size: 16px;\n            color: #2f2f2f;\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"ErrorMsg bad\">\n        <div class=\"ErrorMsg-header\">Select your Workpiece Color </div>\n        <div class=\"ErrorMsg-message\">\n        Please ensure that the temperature and humidity are within the limits before starting production.<br/> <br/>\nThis form triggers a fully automated production process and storage.\n\n        </div>\n    </div>\n\n    \n\n</body>\n</html>\n",
      "type": "html",
      "layout": {
        "row": "Row_1tum75e",
        "columns": null
      },
      "id": "Field_1o5zjtg"
    }
